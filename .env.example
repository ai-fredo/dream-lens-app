# DreamLens API — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- Supabase --------------------------------------------------------------
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Anon (public) key — used for request-scoped, RLS-bound client access.
SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key — bypasses RLS. Server-side only, never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AI providers -----------------------------------------------------------
# Used for dream transcription / auxiliary AI features.
OPENAI_API_KEY=sk-your-openai-api-key
# Used for dream interpretation (Claude).
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins. Must include the landing-page
# origin, or the public demo endpoint will be CORS-blocked in browsers.
CORS_ALLOWLIST=http://localhost:3000,https://your-landing-page.example.com

# --- Observability (optional) ------------------------------------------------
# Sentry DSN. If unset, Sentry is not initialized.
SENTRY_DSN=
# Log level for the Winston logger (e.g. debug, info, warn, error). Defaults to info.
LOG_LEVEL=info

# --- Server ------------------------------------------------------------------
# Port the API listens on. Defaults to 3000 if unset.
PORT=3000
